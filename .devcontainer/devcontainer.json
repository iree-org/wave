{
	"name": "devcontainer",
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"UBUNTU_VERSION": "24.04",
			"ROCM_VERSION": "6.4",
			"LLVM_VERSION": "20",
			"PYTHON_VERSION": "3.12"
		}
	},
	"runArgs": [
		"--device=/dev/kfd",
		"--device=/dev/dri",
		"--group-add=video",
		"--ipc=host",
		"--network=host"
	],
	"capAdd": [
		"SYS_PTRACE"
	],
	"securityOpt": [
		"seccomp=unconfined"
	],
	"containerUser": "ubuntu",
	"mounts": [
		"source=${localWorkspaceFolderBasename}-venv,target=${containerWorkspaceFolder}/.venv,type=volume"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-python.black-formatter",
				"ms-python.mypy-type-checker",
				"ms-python.debugpy",
				"ms-python.vscode-python-envs",
				"llvm-vs-code-extensions.vscode-mlir"
			]
		}
	},
	"postCreateCommand": "sudo chown ubuntu .venv"
}
